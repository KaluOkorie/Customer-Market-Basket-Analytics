  <dashboards>
    <dashboard name='Customer &amp; Sales Story.' type='storyboard'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#0f1115' fontname='Arial Hebrew' fontsize='16'>Online Retail: A Customer &amp; Sales Story</run>
          </formatted-text>
        </title>
      </layout-options>
      <style />
      <size maxheight='964' maxwidth='916' minheight='964' minwidth='916' sizing-mode='fixed' />
      <zones>
