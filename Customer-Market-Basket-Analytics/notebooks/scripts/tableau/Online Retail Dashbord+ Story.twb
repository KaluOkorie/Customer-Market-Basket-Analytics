          </mapsources>
          <datasource-dependencies datasource='federated.18z8dhl0hqz5rn17a6k8k05etjts'>
            <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column caption='Total Price' datatype='real' default-format='c&quot;£&quot;#,##0,.00K;-&quot;£&quot;#,##0,.00K' name='[TotalPrice]' role='measure' type='quantitative' />
