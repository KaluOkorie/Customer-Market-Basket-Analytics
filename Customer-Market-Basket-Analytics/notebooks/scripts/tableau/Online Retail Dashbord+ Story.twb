          <zone h='98340' id='8' param='vert' removable='false' type-v2='layout-flow' w='98254' x='873' y='830'>
            <zone h='3320' id='9' type-v2='title' w='98254' x='873' y='830'>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='4' />
              </zone-style>
            </zone>
            <zone h='95020' id='1' param='vert' removable='false' type-v2='layout-flow' w='98254' x='873' y='4150'>
              <zone h='10477' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98254' x='873' y='4150' />
              <zone h='84543' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98254' x='873' y='14627'>
                <flipboard active-id='8' nav-type='caption' show-nav-arrows='true'>
                  <story-points>
                    <story-point caption='Insight from 2011 sales data' captured-sheet='Monthly Revenue Trend' id='2' />
                    <story-point caption='Star Performers – Top Products' captured-sheet='Top 10 Products by Revenue' id='3'>
                      <capturedDeltas>
                        <worksheet name='Top 10 Products by Revenue'>
                          <selection-collection />
                        </worksheet>
                      </capturedDeltas>
                    </story-point>
                    <story-point caption='Who Are Our Customers?' captured-sheet='Customer Segments' id='4' />
                    <story-point caption='Where in the World?' captured-sheet='Revenue by Country' id='5'>
                      <capturedDeltas>
                        <worksheet name='Revenue by Country'>
                          <style delta-type='added'>
                            <style-rule element='axis'>
                              <encoding attr='space' class='0' field='[federated.18z8dhl0hqz5rn17a6k8k05etjts].[Latitude (generated)]' field-type='quantitative' max='9503515.5091336481' min='3559432.6316759796' projection='EPSG:3857' range-type='fixed' scope='rows' type='space' />
                              <encoding attr='space' class='0' field='[federated.18z8dhl0hqz5rn17a6k8k05etjts].[Longitude (generated)]' field-type='quantitative' max='42698254.913662732' min='37312826.702640012' projection='EPSG:3857' range-type='fixed' scope='cols' type='space' />
                            </style-rule>
                          </style>
                        </worksheet>
                      </capturedDeltas>
                    </story-point>
                    <story-point caption='RFM Heatmap' captured-sheet='RFM Heatmap' id='6'>
                      <capturedDeltas>
                        <worksheet name='RFM Heatmap'>
                          <selection-collection>
                            <tuple-selection>
                              <tuple-reference>
                                <tuple-descriptor>
                                  <pane-descriptor>
                                    <x-fields>
                                      <field>[federated.18z8dhl0hqz5rn17a6k8k05etjts].[none:R_Score:ok]</field>
                                    </x-fields>
                                    <y-fields>
                                      <field>[federated.18z8dhl0hqz5rn17a6k8k05etjts].[none:F_Score:ok]</field>
                                    </y-fields>
                                  </pane-descriptor>
                                  <columns>
                                    <field>[federated.18z8dhl0hqz5rn17a6k8k05etjts].[none:F_Score:ok]</field>
                                    <field>[federated.18z8dhl0hqz5rn17a6k8k05etjts].[none:R_Score:ok]</field>
                                    <field>[federated.18z8dhl0hqz5rn17a6k8k05etjts].[usr:Calculation_2795278707834892:qk]</field>
                                  </columns>
                                </tuple-descriptor>
                                <tuple>
                                  <value>1</value>
                                  <value>2</value>
                                  <value>202</value>
                                </tuple>
                              </tuple-reference>
                            </tuple-selection>
                          </selection-collection>
                        </worksheet>
                      </capturedDeltas>
                    </story-point>
                    <story-point caption='Association Rules&#10;What Do Customers Buy Together?' captured-sheet='Top Product Association Rules' id='7' />
                    <story-point caption='Summary' captured-sheet='' id='8' />
                  </story-points>
                </flipboard>
              </zone>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone flipboard-zone-id='5' h='19398' hidden='true' id='6' story-point-id='2' type-v2='text' w='45833' x='4167' y='17946'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#0f1115' fontname='Arial Hebrew' fontsize='15' italic='true'>Revenue peaked in November 2011, likely due to Christmas shopping. Let’s explore what drove those sales.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='7469' hidden='true' id='10' story-point-id='2' type-v2='text' w='36152' x='47549' y='68776'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#0f1115' fontname='Arial Hebrew' fontsize='15'>Monthly Sales Over Time</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='11929' hidden='true' id='11' story-point-id='3' type-v2='text' w='88603' x='3064' y='44606'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#0f1115' fontname='Arial Hebrew' fontsize='15' italic='true'>The Regency Cakestand and Heart T‑Light Holder are the top revenue generators. These are key items to keep in stock.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='9544' hidden='true' id='12' story-point-id='4' type-v2='text' w='71616' x='5677' y='69295'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#0f1115' fontname='Arial Hebrew' fontsize='15' italic='true'>We have a healthy mix: many VIPs (high value) but also a large ‘At‑Risk’ group. Retaining them could boost revenue.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='5602' hidden='true' id='13' story-point-id='4' type-v2='text' w='44978' x='20087' y='36307'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#0f1115' fontname='Arial Hebrew' fontsize='18'>Customer Segments (Pie Chart)</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='3112' hidden='true' id='14' story-point-id='5' type-v2='text' w='22271' x='32096' y='17220'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#0f1115' fontname='Arial Hebrew' fontsize='11'>Revenue by Country</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='9544' hidden='true' id='15' story-point-id='5' type-v2='text' w='69323' x='7424' y='81950'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#0f1115' fontname='Arial Hebrew' fontsize='15' italic='true'>The UK dominates, but the Netherlands and Ireland are strong secondary markets. Opportunity to expand</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='11929' hidden='true' id='16' story-point-id='6' type-v2='text' w='94105' x='3493' y='50104'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#0f1115' fontname='Arial Hebrew' fontsize='15' italic='true'>The heatmap shows most customers have high Recency scores (recent buyers) but lower Frequency. We need to encourage repeat purchases.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='9544' hidden='true' id='17' story-point-id='7' type-v2='text' w='78275' x='873' y='51971'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#0f1115' fontname='Arial Hebrew' fontsize='15' italic='true'>These rules suggest strong product affinities – perfect for cross‑selling and store layout optimisation.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='27282' id='18' story-point-id='8' type-v2='text' w='48581' x='6004' y='20228'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#0f1115' fontname='Arial Hebrew' fontsize='15' italic='true'>Key Takeaways:</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#0f1115' fontname='Arial Hebrew' fontsize='15' italic='true'>– November is peak season.</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#0f1115' fontname='Arial Hebrew' fontsize='15' italic='true'>– Top 2 products drive 20% of revenue.</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#0f1115' fontname='Arial Hebrew' fontsize='15' italic='true'>– VIPs are 926 customers, but 1,323 are At‑Risk.</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#0f1115' fontname='Arial Hebrew' fontsize='15' italic='true'>– Use association rules for cross‑selling.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='12863' id='19' story-point-id='8' type-v2='text' w='43777' x='28603' y='62656'>
          <formatted-text>
            <run fontname='Arial Black' fontsize='15'>THANK YOU !</run>
          </formatted-text>
        </zone>
      </zones>
      <simple-id uuid='{65BA031C-3078-4EF3-BBCD-03E5EEDCAA06}' />
    </dashboard>
    <dashboard enable-sort-zone-taborder='true' name='Dashboard 1'>
      <style />
      <size maxheight='960' maxwidth='750' minheight='560' minwidth='720' sizing-mode='range' />
      <zones>
